# =============================================================================
# helios-compose secrets — copy to .env and fill in values
# NEVER commit .env to Git — store in Bitwarden + back up to TrueNAS
# =============================================================================

# --- hel-prod-apps-coolify ---------------------------------------------------
COOLIFY_APP_ID=                         # generate: openssl rand -hex 16
COOLIFY_APP_KEY=                        # generate: openssl rand -base64 32
COOLIFY_APP_URL=https://coolify.maakleerplek.be
COOLIFY_DB_NAME=coolify
COOLIFY_DB_USER=coolify
COOLIFY_DB_PASSWORD=                    # strong password
COOLIFY_PUSHER_APP_ID=                  # generate: openssl rand -hex 8
COOLIFY_PUSHER_APP_KEY=                 # generate: openssl rand -hex 16
COOLIFY_PUSHER_APP_SECRET=              # generate: openssl rand -hex 32

# --- hel-prod-inv-netbox -----------------------------------------------------
NETBOX_DB_NAME=netbox
NETBOX_DB_USER=netbox
NETBOX_DB_PASSWORD=                     # strong password
NETBOX_SECRET_KEY=                      # generate: openssl rand -hex 50
NETBOX_ALLOWED_HOSTS=netbox.maakleerplek.be
NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=ict@maakleerplek.be
NETBOX_SUPERUSER_PASSWORD=              # strong password — change after first login
NETBOX_OIDC_ENDPOINT=https://auth.maakleerplek.be/application/o/netbox/
NETBOX_OIDC_CLIENT_ID=                  # from Authentik
NETBOX_OIDC_CLIENT_SECRET=              # from Authentik
