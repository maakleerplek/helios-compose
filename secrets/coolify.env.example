# =============================================================================
# Coolify app config — copy to coolify.env and fill in values
# This file is mounted directly into the Coolify container as /var/www/html/.env
# NEVER commit coolify.env to Git
# =============================================================================

APP_NAME=Coolify
APP_ID=
APP_KEY=
APP_ENV=production
APP_URL=

DB_CONNECTION=pgsql
DB_HOST=hel-prod-apps-coolify-db
DB_PORT=5432
DB_DATABASE=coolify
DB_USERNAME=coolify
DB_PASSWORD=

REDIS_HOST=hel-prod-apps-coolify-redis
REDIS_PORT=6379
REDIS_PASSWORD=null

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=hel-prod-apps-coolify-realtime
PUSHER_BACKEND_HOST=hel-prod-apps-coolify-realtime
PUSHER_PORT=6001
PUSHER_BACKEND_PORT=6001
PUSHER_SCHEME=http
