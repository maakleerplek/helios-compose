# =============================================================================
# helios-compose secrets — copy to helios.env and fill in values
# NEVER commit helios.env to Git — store in Bitwarden + back up to TrueNAS
# =============================================================================

# --- hel-prod-mon (monitoring) -----------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=           # strong password
GRAFANA_DOMAIN=monitor.int.maakleerplek.be

# --- hel-prod-apps-taiga -----------------------------------------------------
TAIGA_DB_NAME=taiga
TAIGA_DB_USER=taiga
TAIGA_DB_PASSWORD=                # openssl rand -hex 16
TAIGA_SECRET_KEY=                 # openssl rand -hex 32
TAIGA_RABBITMQ_USER=taiga
TAIGA_RABBITMQ_PASS=              # openssl rand -hex 16
TAIGA_DOMAIN=ict.maakleerplek.be

# --- hel-prod-apps-truedesk --------------------------------------------------
TRUEDESK_DOMAIN=support.maakleerplek.be
TRUEDESK_DB_USER=trudesk
TRUEDESK_DB_PASSWORD=              # openssl rand -hex 16
